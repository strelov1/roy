# Copy to .env and fill in. docker-compose will refuse to start if
# ROY_JWT_SECRET is unset.

# --- roy-management: required ---
# Must be >=32 ASCII bytes. Generate with:
#   openssl rand -hex 32
ROY_JWT_SECRET=

# --- roy-management: bootstrap user (created only on first launch) ---
# Leave both unset (commented out) to have roy-management generate a 32-char
# hex password and print it to stderr exactly once — read it with
# `docker compose logs roy-management`. Set them to override.
# Password must be ≥8 chars when set.
# ROY_BOOTSTRAP_USERNAME=root
# ROY_BOOTSTRAP_PASSWORD=changeme123

# --- roy-workspace: where the browser talks to the gateway ---
# Baked into the SPA at build time. Change if you publish behind a domain
# or non-default port, then `docker compose build roy-workspace`.
VITE_ROY_WS_URL=ws://localhost:8788

# --- Keys / tokens for ACP agents ---
# Some ACP CLIs read a key from env instead of an OAuth session file.
# Uncomment what you use — compose forwards these into roy-daemon, which
# inherits env to every spawned agent process.
#
# If you prefer logging in via the host CLI (claude login, gemini auth, …),
# leave these empty: docker-compose.yml already bind-mounts ~/.claude,
# ~/.gemini, ~/.codex, ~/.config/opencode read-only.
#
# ANTHROPIC_API_KEY=
# CLAUDE_CODE_OAUTH_TOKEN=     # long-lived OAuth token from `claude setup-token` (Pro/Max)
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
